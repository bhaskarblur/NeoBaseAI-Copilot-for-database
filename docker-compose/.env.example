# Backend Env:

IS_DOCKER=true # true/false
PORT=3000 # Backend Port
ENVIRONMENT=DEVELOPMENT # DEVELOPMENT, PRODUCTION
MAX_CHATS_PER_USER=1 # 0 for trial mode(2 connections), 1 for unlimited
CORS_ALLOWED_ORIGIN=http://localhost:5173 # Frontend exposed base url (Example: https://app.neobase.cloud)
LANDING_PAGE_CORS_ALLOWED_ORIGIN=http://localhost:5174 # Landing Page exposed base url (Example: https://neobase.cloud)
NEOBASE_ADMIN_USERNAME=bhaskar-07 # Your admin username
NEOBASE_ADMIN_PASSWORD=bhaskar-07 # Your admin password
SCHEMA_ENCRYPTION_KEY=f9e34567890123456789012345678901 # 32 bytes for AES-256
JWT_SECRET=f9e34567890123456789012345678901 # 32 bytes key
USER_JWT_EXPIRATION_MILLISECONDS=1000*60*10 # 10 minutes
USER_JWT_REFRESH_EXPIRATION_MILLISECONDS=1000*60*60*24*10 # 10 days

# Used for storing user, connections, chats etc
NEOBASE_MONGODB_URI=mongodb://neobase:neobase@neobase-mongodb:27017/neobase?authSource=admin
NEOBASE_MONGODB_NAME=neobase

# Used for storing user sessions, DB schema
NEOBASE_REDIS_HOST=neobase-redis
NEOBASE_REDIS_PORT=6379
NEOBASE_REDIS_USERNAME=neobase
NEOBASE_REDIS_PASSWORD=default

# OpenAI API Key - If configured, enables GPT-4 Omni, GPT-4 Turbo, GPT-3.5 Turbo, O1, and other OpenAI models
OPENAI_API_KEY=<openai-api-key> # Your OpenAI Api Key

# Gemini API Key - If configured, enables Gemini 2.0 Flash, Gemini 2.0 Pro, Gemini 1.5 Pro/Flash, and other Gemini models
GEMINI_API_KEY=<gemini-api-key> # Your Gemini Api Key

# Claude API Key - If configured, enables Claude 3.5 Sonnet, Claude 3 Opus, and other Anthropic Claude models
CLAUDE_API_KEY=<claude-api-key> # Your Claude API Key from Anthropic

# Ollama Base URL - If configured, enables self-hosted open-source models (Llama, Mistral, CodeLlama, etc.)
OLLAMA_BASE_URL=http://localhost:11434 # Your Ollama instance URL (leave empty to disable)

# Example DB for Development Environment
EXAMPLE_DB_TYPE=
EXAMPLE_DB_HOST=
EXAMPLE_DB_PORT=
EXAMPLE_DB_NAME=
EXAMPLE_DB_USERNAME=
EXAMPLE_DB_PASSWORD=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=NeoBase - AI Database Copilot
SMTP_FROM_EMAIL=your-email@gmail.com

# PostgreSQL for Spreadsheet (CSV/Excel) Data Storage
SPREADSHEET_POSTGRES_HOST=localhost
SPREADSHEET_POSTGRES_PORT=5432
SPREADSHEET_POSTGRES_DATABASE=neobase_spreadsheet_storage
SPREADSHEET_POSTGRES_USERNAME=neobase_spreadsheet
SPREADSHEET_POSTGRES_PASSWORD=your_secure_password_here
SPREADSHEET_POSTGRES_SSL_MODE=disable # disable, require, verify-ca, verify-full

# Encryption for Spreadsheet data
SPREADSHEET_DATA_ENCRYPTION_KEY=spreadsheet_encryption_key_32byt # 32 bytes for AES-GCM

# Qdrant Vector DB Configuration (used for RAG pipeline)
QDRANT_HOST=neobase-qdrant # Qdrant host (use "neobase-qdrant" in Docker, "localhost" for manual setup)
QDRANT_PORT=6334 # Qdrant gRPC port
QDRANT_API_KEY= # Qdrant API key (optional for local, required for Qdrant Cloud)
QDRANT_USE_TLS=false # Use TLS for Qdrant connection (set true for Qdrant Cloud)

# Embedding Model Configuration (used for RAG vectorization)
# Provider: "openai" or "gemini" — auto-detected from API keys if left empty
# OpenAI models: text-embedding-3-small (default, 1536d), text-embedding-3-large (3072d), text-embedding-ada-002 (1536d)
# Gemini models: gemini-embedding-001 (default, 768d, newest), text-embedding-004 (768d), embedding-001 (768d, legacy)
EMBEDDING_PROVIDER=gemini # openai or gemini (auto-detected if empty)
EMBEDDING_MODEL=gemini-embedding-001 # e.g., text-embedding-3-small or gemini-embedding-001 (uses provider default if empty)


# ----- #

# Client Env:
VITE_FRONTEND_BASE_URL=http://localhost:5173/ # Client hosted url with / (Example: https://neobase.frontend.com/)
VITE_API_URL=http://localhost:3000/api # Backend hosted url, with /api (Example: https://neobase.backend.com/api)
VITE_ENVIRONMENT=DEVELOPMENT # DEVELOPMENT, PRODUCTION
VITE_NEOBASE_WHITELIST_ADDRESSES=192.168.1.1 # Comma-separated NeoBase server addresses for IP whitelisting

